# AI Providers
GEMINI_API_KEY=your_gemini_api_key_here
OPENAI_API_KEY=your_openai_api_key_here  # Optional fallback

# Security
MASTER_API_KEY=generate_secure_random_key_here
SECRET_KEY=generate_another_secure_random_key_here
JWT_SECRET=${SECRET_KEY}  # Or separate if needed

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ai_ticket_classifier

# Redis
REDIS_URL=redis://redis:6379/0

# CORS (IMPORTANT - set your domains!)
ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# Environment
FLASK_ENV=production
LOG_LEVEL=INFO
FORCE_HTTPS=false  # Set to true in production with HTTPS

# Optional: Monitoring
SENTRY_DSN=your_sentry_dsn_here  # Optional
PROMETHEUS_PUSHGATEWAY=http://pushgateway:9091  # Optional

# Feature Flags
ALLOW_PROVIDERLESS=false  # Only for testing

# Stripe (for billing/monetization)
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here
STRIPE_PRICE_STARTER=price_starter_monthly_id_from_stripe_dashboard
STRIPE_PRICE_PRO=price_pro_monthly_id_from_stripe_dashboard
